# BINAA Backend — Environment Variables
# Copy to .env and customize as needed.

# Comma-separated list of allowed CORS origins.
# Default (dev): http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:5173
# Production example: https://binaa.dz,https://www.binaa.dz
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:5173
